digraph LeanProofDependencies {
  graph [
    rankdir=LR,
    bgcolor="white",
    compound=false,
    splines=true,
    overlap=false,
    fontsize=12,
    fontname="Helvetica",
    label="Lean proof dependency graph (theorem IDs match formal/AlignmentProofSpine/*.lean)",
    labelloc="t"
  ];

  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#444444", fillcolor="#F8F8F8"];
  edge [fontname="Helvetica", fontsize=9, color="#555555", arrowsize=0.8];

  // Boundaries (ch6–7, 10, 36)
  P05 [label="P05 Boundary predicate\nBoundaryCondition ⇒ agent candidate", fillcolor="#EAF3FF"];
  P06 [label="P06 Blanket zero external gain\nBlanket ⇒ no external predictive gain", fillcolor="#EAF3FF"];
  P07 [label="P07 Exact boundary\nExact ⇒ ε-boundary", fillcolor="#EAF3FF"];
  P08 [label="P08 Boundary violation blocks candidate\nBoundaryViolation ⇒ ¬BoundaryCandidate", fillcolor="#EAF3FF"];
  P09 [label="P09 Observational non-identifiability\nobs-equivalent models, different goal", fillcolor="#EAF3FF"];
  P09A [label="Access non-identifiability\naccess-equivalent, different goal", fillcolor="#EAF3FF"];
  PCID [label="[NEW]\nCID incentives\nnot abstraction-invariant", fillcolor="#EAF3FF", color="#1F77B4", penwidth=2.2];
  P09K [label="K-equivalence limit\nsmoothed channel erases raw boundary", fillcolor="#EAF3FF"];
  P36 [label="P36 Handle-operation refinement\nhandle operation distinguishes models", fillcolor="#EAF3FF"];
  P36M [label="Smoothing margin\nΔ > 2δK + 2εest", fillcolor="#EAF3FF"];

  // Capability (ch11–14, 33, 36)
  P10 [label="P10 B-IQ upper bound\nBIQ ≤ Csens + Cact", fillcolor="#EAF3FF"];
  P11 [label="P11 Capacity monotonicity\nhigher IO ceiling ⇒ higher max BIQ", fillcolor="#EAF3FF"];
  P12 [label="P12 Coordination bottleneck\ncoordination can cap collective BIQ", fillcolor="#EAF3FF"];
  P13 [label="P13 Control outpaces correction\nRisk = Control − CCI", fillcolor="#EAF3FF"];
  P32 [label="P32 Cooperativity threshold\nκ>1 ⇔ b·p·ρ>c", fillcolor="#EAF3FF"];
  P43 [label="P43 Small-step drift accumulates\npositive drift eventually crosses bound", fillcolor="#EAF3FF"];
  P43H [label="Hidden-rate accumulation\npositive hidden BIQ eventually crosses threshold", fillcolor="#EAF3FF"];

  // Bundles (ch15–23)
  P14 [label="P14 Bundle factorization\nsame bundle ⇒ same policy output", fillcolor="#EFFBEA"];
  P15 [label="P15 Same policy ≠ bundle geometry\ncounterexample", fillcolor="#EFFBEA"];
  P17 [label="P17 Same labels ≠ bearer map\nontology-shift counterexample", fillcolor="#EFFBEA"];
  P18 [label="P18 Marginals ≠ tradeoffs\ntradeoff counterexample", fillcolor="#EFFBEA"];
  P19 [label="[SUBSUMED]\nP19 Scalar reward as k=1 bundle\nIRL embeds in bundle model", fillcolor="#EFFBEA", color="#2E7D32", penwidth=2.2];
  PCIRL [label="[NEW]\nCIRL / reward inference\n≠ bundle preservation", fillcolor="#EFFBEA", color="#1F77B4", penwidth=2.2];
  P20 [label="P20 Positive intentional gain\nΔL>0 ⇒ MDL prefers intentional model", fillcolor="#EFFBEA"];
  P21 [label="P21 Goal-transport gain\nΔL_transport>0 ⇒ prefer transport model", fillcolor="#EFFBEA"];
  P22a [label="P22a Full transport ⇒ semantic transport", fillcolor="#EFFBEA"];
  P22b [label="P22b Semantic ≠ full transport\ncounterexample", fillcolor="#EFFBEA"];
  P22T [label="Syntactic tiling ≠ import-preserving transport\ncounterexample", fillcolor="#EFFBEA"];

  // Correction (ch24–27)
  P23 [label="P23 No handle control, no correction\nno legitimate reaching handle ⇒ ¬Correction", fillcolor="#FFF0FB"];
  P24 [label="P24 Weakest handle capacity\npath capacity ≤ each link; CCI export", fillcolor="#FFF0FB"];
  P24S [label="[SUBSUMED]\nShutdown projection\nCorrectionIntegrity ⇒ Thornley shutdownability", fillcolor="#FFF0FB", color="#2E7D32", penwidth=2.2];
  P24X [label="Shutdownability ≠ broad CCI\ncounterexample", fillcolor="#FFF0FB"];
  P24I [label="[NEW]\nSafe interruptibility\n≠ broad CCI", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P24L [label="[NEW]\nLow impact\n≠ correction preservation", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P24H [label="[NEW]\nCorrection can require\nhigh impact", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P24Q [label="[NEW]\nQuantilized local action\n≠ trajectory CCI", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P25 [label="P25 Obedience ≠ corrigibility\ncounterexample", fillcolor="#FFF0FB"];
  P25C [label="Act-based satisfaction ≠ stable corrigibility\ncounterexample", fillcolor="#FFF0FB"];
  P25D [label="[NEW]\nDebate truth\n≠ correction preservation", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P25A [label="[NEW]\nAmplification\n≠ correction contraction", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P25E [label="[NEW]\nLatent readout\n≠ correction uptake", fillcolor="#FFF0FB", color="#1F77B4", penwidth=2.2];
  P26 [label="P26 Preserves update without fixed point\ncounterexample", fillcolor="#FFF0FB"];

  // Successors (ch28–31)
  P27 [label="P27 Successor invariant chain\nP A₀ ∧ preserved ⇒ ∀ successors P", fillcolor="#F4EEFF"];
  P28 [label="P28 Missing invariant blocks successor safety\nmissing CCI or U_S ⇒ ¬SuccessorSafe", fillcolor="#F4EEFF"];
  P29 [label="P29 Self-control gap increases risk\nmore self-control, same visibility ⇒ higher gap", fillcolor="#F4EEFF"];

  // Adversarial / socio-technical (ch32–37)
  P31 [label="P31 Safe agent selected against\nunsafe agent has higher DeploymentMass", fillcolor="#FFF0EC"];
  P33 [label="P33 No open edges, no large component\ncooperation graph lemma", fillcolor="#FFF0EC"];
  P34 [label="P34 Host-capacity aliasing\n|Signal|<|Attack| ⇒ no injective detector", fillcolor="#FFF0EC"];
  P37 [label="P37 Goal laundering\nstated goal = inferred goal counterexample", fillcolor="#FFF0EC"];

  // Philosophy (ch41–44)
  P41 [label="P41 Current value preservation\n≠ legitimacy", fillcolor="#FFF0EC"];
  P42 [label="P42 Continuity criteria\ncan disagree", fillcolor="#FFF0EC"];
  P44 [label="P44 Technical invariants\ndo not determine legitimacy", fillcolor="#FFF0EC"];
  P45 [label="P45 Layered alignment has\nphilosophical boundary", fillcolor="#FFF0EC"];

  // Certification (ch1–5, 35, 39, 44)
  P01 [label="P01 Basin invariant\nSafe x₀ ∧ closed step ⇒ ∀n Safe", fillcolor="#F2F2F2"];
  P35 [label="P35 Basin stability induction\nBasinStable step preserves region", fillcolor="#F2F2F2"];
  P02 [label="P02 Layered alignment\nany missing layer blocks conjunction", fillcolor="#F2F2F2"];
  P30 [label="P30 Certified-class safety\nControl ≤ CCI + δ ⇒ Risk ≤ δ", fillcolor="#F2F2F2"];
  P40 [label="P40 Unsupported leaf blocks\nsafety-case root", fillcolor="#F2F2F2"];
  P30T [label="Top: certified_class_safety_from_spine_and_bridges\nLayeredAligned ∧ Risk ≤ δ", fillcolor="#F2F2F2"];

  // Bridge assumptions (MB1–MB8; MB7 split)
  MB1 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB1 Estimator soundness\nraw traces ⇒ true ε-boundary posterior"];
  MB2 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB2 Bundle identifiability\nbehavior ⇒ stable B,W,Φ"];
  MB3 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB3 Bearer import theorem\nhuman Φ ⇒ substrate Φ′"];
  MB4 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB4 Correction legitimacy criterion\nnon-manipulated deliberation"];
  MB5 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB5 Ontology-shift successor audit\nsuccessors preserve B,Φ,CCI"];
  MB6 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB6 Institutional selection bridge\nDeploymentMass / basin selection"];
  MB7a [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB7a Access-model soundness\nboundary + adequate handles ⇒ access robust"];
  MB7b [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB7b Filter-family coverage\naccess robust + filter coverage ⇒ hidden BIQ bounded"];
  MB7c [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB7c Hidden-BIQ robustness\ncorrection + hidden BIQ bound ⇒ adversarial robustness"];
  MB8 [shape=diamond, style="filled", fillcolor="#FFE6E6", color="#CC3333", label="MB8 CEV/process convergence\nupdate operator well-behaved"];

  // Boundary chain
  P05 -> P06 [label="C-BND: blanket implies candidate"];
  P06 -> P07 [label="C-BND: exact case"];
  P05 -> P08 [label="C-BND: violation blocks"];
  P05 -> P10 [label="C-BIQ: blanket-defined IO"];
  P10 -> P11 [label="C-BIQ: ceiling"];
  P11 -> P13 [label="C-RISK: capability/control side"];

  // Bundle / transport chain
  P14 -> P19 [label="C-VB: bundle generalizes scalar reward"];
  P19 -> PCIRL [label="C-CIRL: reward inference weaker"];
  P14 -> P15 [label="C-VB: policy ≠ geometry"];
  P14 -> P17 [label="C-BEARER: bundle needs application map"];
  P20 -> P21 [label="C-GT: add transport map"];
  P19 -> P20 [label="C-EIS: intentional reward model"];
  P21 -> P22a [label="C-TRANSPORT: full ⇒ semantic"];
  P22a -> P22b [label="C-TRANSPORT: semantic not full"];
  P22b -> P22T [label="C-TILING: syntactic special case"];
  P17 -> P22b [label="C-TRANSPORT: bearer not semantic"];
  P18 -> P22b [label="C-TRANSPORT: tradeoffs not semantic"];
  P15 -> P37 [label="C-LAUNDER: policy hides geometry"];
  P17 -> P37 [label="C-LAUNDER: labels hide Φ drift"];
  P22b -> P37 [label="C-LAUNDER: semantic insufficient"];
  P14 -> MB2 [label="C-SAMPLE: tractable if identifiable", style=dashed];

  // Correction chain (handle-controlled)
  P23 -> P24 [label="C-CC: channel as handle path"];
  P24 -> P24S [label="C-SHUTDOWN: one-bit projection"];
  P24S -> P24X [label="C-SHUTDOWN: converse fails"];
  P24S -> P24I [label="C-INTERRUPT: incentive bit weaker"];
  P24 -> P24L [label="C-IMPACT: low impact weaker"];
  P24L -> P24H [label="C-IMPACT: preservation may be costly"];
  P24 -> P24Q [label="C-QUANT: local action not trajectory"];
  P24 -> P25 [label="C-CEV: obedience lacks update path"];
  P25 -> P25C [label="C-CHRISTIANO: local satisfaction not invariant"];
  P25 -> P25D [label="C-DEBATE: judge channel"];
  P25 -> P25A [label="C-AMPLIFY: no contraction"];
  P25 -> P25E [label="C-ELK: readout not uptake"];
  P24 -> P13 [label="C-RISK: correction capacity (CCI)"];
  P25 -> P26 [label="C-CEV: update without fixed point"];
  P22T -> P27 [label="C-SUC: tiling needs import transport"];
  P22b -> P27 [label="C-SUC: transport property"];
  P24 -> P27 [label="C-SUC: correction property"];
  P27 -> P28 [label="C-SUC: missing field blocks safety"];
  P28 -> P02 [label="C-LAYER: successor layer"];
  P29 -> P13 [label="C-RISK: self-control gap"];

  // Adversarial measurement
  P09 -> P09A [label="C-ACCESS: weaker observational id"];
  P09 -> PCID [label="C-CID: variable ontology"];
  P09 -> P36 [label="C-ADV: need perturbation"];
  P09A -> P36 [label="C-ACCESS: need handle tests"];
  P09 -> P09K [label="C-SMOOTH: channel erases raw boundary"];
  P09K -> P36M [label="C-SMOOTH: quantify recoverability"];
  P34 -> P09 [label="C-ADV: audit aliasing"];
  P43H -> MB7b [label="C-STEALTH: hidden stock must be bounded", style=dashed];

  // MB7 bridge chain (matches certified_class_safety_from_spine_and_bridges)
  MB7a -> MB7b [label="access robust + filter coverage", style=dashed, color="#CC3333"];
  MB7b -> MB7c [label="hidden BIQ bounded", style=dashed, color="#CC3333"];
  MB6 -> MB7c [label="CorrectionIntegrity input", style=dashed, color="#CC3333"];
  MB7c -> P02 [label="C-LAYER: adversarial robustness layer", style=dashed, color="#CC3333"];

  // Socio-technical selection
  P12 -> P31 [label="C-SEL: selection can disfavor safety"];
  P31 -> MB6 [label="C-INST: DeploymentMass model", style=dashed];
  P32 -> P33 [label="C-AB: open-edge predicate"];
  P33 -> P34 [label="C-PARASITE: host-capacity aliasing"];

  // Philosophy limits
  P43 -> P44 [label="C-LIMIT: drift outruns local tests"];
  P41 -> P44 [label="C-NORM: value preservation ≠ legitimacy"];
  P42 -> P44 [label="C-NORM: continuity criteria disagree"];
  P44 -> P45 [label="C-LAYER: philosophical boundary"];
  P45 -> P02 [label="C-LAYER: technical layer not enough"];

  // Certification top
  P35 -> P01 [label="C-AB: basin stability"];
  P01 -> P30 [label="C-CERT: invariant over time"];
  P02 -> P30 [label="C-CERT: all layers present"];
  P13 -> P30 [label="C-CERT: bounded risk gap"];
  P27 -> P30 [label="C-CERT: successor chain bound"];
  P40 -> P30 [label="C-SCASE: assumptions supported"];
  P30 -> P30T [label="C-CERT: bridge-composed top theorem"];
  MB8 -> P02 [label="C-LAYER: correction-process bridge", style=dashed, color="#CC3333"];

  // Bridge gaps into structure
  MB1 -> P05 [label="missing C-UAD-SOUND", style=dashed, color="#CC3333"];
  MB1 -> P09 [label="missing C-OBS-VALID", style=dashed, color="#CC3333"];
  MB2 -> P15 [label="missing C-BUNDLE-ID", style=dashed, color="#CC3333"];
  MB2 -> P21 [label="missing C-GT-ID", style=dashed, color="#CC3333"];
  MB3 -> P17 [label="missing C-BEARER-IMPORT", style=dashed, color="#CC3333"];
  MB3 -> P22b [label="missing C-SUBSTRATE-TRANSPORT", style=dashed, color="#CC3333"];
  MB4 -> P25 [label="missing C-LEGIT-CORR", style=dashed, color="#CC3333"];
  MB4 -> P44 [label="missing C-NORM-LIMIT", style=dashed, color="#CC3333"];
  MB5 -> P27 [label="missing C-ONTO-SUC", style=dashed, color="#CC3333"];
  MB5 -> P28 [label="missing C-AUDIT-COMPOSE", style=dashed, color="#CC3333"];
  MB6 -> P33 [label="missing C-INST-FITNESS / percolation bridge", style=dashed, color="#CC3333"];
  MB6 -> P01 [label="missing C-ATTRACTOR-SELECTION", style=dashed, color="#CC3333"];
  P05 -> MB7a [label="BoundaryAligned input", style=dashed, color="#CC3333"];
  P09A -> MB7a [label="missing C-HANDLE-ADEQUACY", style=dashed, color="#CC3333"];
  P36M -> MB7b [label="margin motivates filter coverage", style=dashed, color="#CC3333"];
  P09K -> MB7b [label="missing C-FILTER-COVERAGE", style=dashed, color="#CC3333"];
  P34 -> MB7b [label="missing C-CAMOUFLAGE-BOUND", style=dashed, color="#CC3333"];
  P43H -> MB7c [label="missing C-RESOURCE-LEDGER", style=dashed, color="#CC3333"];
  P26 -> MB8 [label="missing C-CEV-PROCESS", style=dashed, color="#CC3333"];
  P25 -> MB8 [label="missing C-DELIB-VALID", style=dashed, color="#CC3333"];
}
